generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum LeagueType {
  NFL
  MLB
  ACC
  SEC
  BIG_TEN
}

enum Sport {
  NFL
  MLB
  COLLEGE_FOOTBALL
}

enum Conference {
  NFL
  MLB
  ACC
  SEC
  BIG_TEN
  OTHER
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  username        String    @unique
  passwordHash    String
  isAdmin         Boolean   @default(false)
  resetToken      String?
  resetTokenExp   DateTime?
  createdAt       DateTime  @default(now())

  memberships     LeagueMember[]
  picks           Pick[]
  commissioned    League[]       @relation("Commissioner")
}

model League {
  id             String       @id @default(cuid())
  name           String
  leagueType     LeagueType
  isPublic       Boolean      @default(true)
  passwordHash   String?
  season         Int
  commissionerId String
  createdAt      DateTime     @default(now())

  commissioner   User           @relation("Commissioner", fields: [commissionerId], references: [id])
  members        LeagueMember[]
  picks          Pick[]
  deadlines      PickDeadline[]

  @@index([isPublic])
  @@index([leagueType])
}

model LeagueMember {
  id       String   @id @default(cuid())
  leagueId String
  userId   String
  joinedAt DateTime @default(now())

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId])
}

model Team {
  id           String     @id @default(cuid())
  espnId       String
  abbreviation String
  displayName  String
  conference   Conference
  sport        Sport

  awayGames Game[] @relation("AwayTeam")
  homeGames Game[] @relation("HomeTeam")

  @@unique([espnId, sport])
  @@index([conference])
}

model Game {
  id         String   @id @default(cuid())
  espnGameId String
  sport      Sport
  week       Int
  season     Int
  awayTeamId String
  homeTeamId String
  kickoff    DateTime
  status     String   @default("scheduled")
  awayScore  Int?
  homeScore  Int?
  winner     String?

  awayTeam Team   @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam Team   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  picks    Pick[]

  @@unique([espnGameId, sport])
  @@index([sport, season, week])
}

model Pick {
  id        String   @id @default(cuid())
  userId    String
  leagueId  String
  gameId    String
  pick      String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId, gameId])
  @@index([leagueId, userId])
}

model PickDeadline {
  id       String   @id @default(cuid())
  leagueId String
  week     Int
  season   Int
  deadline DateTime

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, week, season])
}
